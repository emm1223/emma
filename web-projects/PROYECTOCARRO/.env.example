# ============ VARIABLES DE AMBIENTE - TEMPLATE ============
# Copiar este archivo a .env.local y llenar con tus valores
# NUNCA commitear .env.local a Git
# 
# SEGURIDAD: 
# - Todos los JWT_* secrets deben ser al menos 32 caracteres aleatorios
# - Usar 'openssl rand -base64 32' para generar valores seguros
# - Cambiar valores por defecto en desarrollo antes de ir a producción

# ============ ADMIN AUTHENTICATION ============
# Username para login del admin (cambiar del valor por defecto)
NEXT_PUBLIC_ADMIN_USERNAME=admin

# Password hash de admin - Generar con bcryptjs (salt 10)
# Ejemplo con Node.js: await bcrypt.hash('password123', 10)
# CRÍTICO: Debe estar configurado en producción
ADMIN_PASSWORD_HASH=

# ============ JWT TOKENS ============
# Secret para firmar access tokens (expiración 15 minutos)
# Generar: openssl rand -base64 32
# CRÍTICO: Cambiar antes de producción, min 32 caracteres
JWT_SECRET=fallback-secret-key-change-in-production

# Secret para firmar refresh tokens (expiración 7 días)
# Generar: openssl rand -base64 32
# CRÍTICO: Cambiar antes de producción, min 32 caracteres
JWT_REFRESH_SECRET=fallback-refresh-secret-change-in-production

# ============ RATE LIMITING ============
# Máximo de requests permitidos en el time window
# Default: 100 requests por 15 minutos
RATE_LIMIT_REQUESTS=100

# Ventana de tiempo para rate limiting en milisegundos
# Default: 900000 ms = 15 minutos
RATE_LIMIT_WINDOW_MS=900000

# ============ BRUTE FORCE PROTECTION ============
# Máximo de intentos fallidos antes de bloquear
# Default: 5 intentos
BRUTE_FORCE_MAX_ATTEMPTS=5

# Duración del bloqueo en milisegundos
# Default: 900000 ms = 15 minutos
BRUTE_FORCE_LOCKOUT_DURATION_MS=900000

# Ventana de reset de intentos en milisegundos
# Default: 3600000 ms = 1 hora
BRUTE_FORCE_RESET_WINDOW_MS=3600000

# ============ AUDIT LOGGING ============
# Tamaño máximo del buffer de audit logs en memoria
AUDIT_LOG_MAX_SIZE=5000

# Debug mode para audit logging (solo desarrollo)
DEBUG_AUDIT=false

# ============ ENVIRONMENT ============
# Environment: development, production
NODE_ENV=development

# URL pública de la aplicación
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============ OPCIONAL - EXTERNAL SERVICES ============
# Firebase
# NEXT_PUBLIC_FIREBASE_API_KEY=
# FIREBASE_ADMIN_PRIVATE_KEY=

# Supabase
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# SendGrid para email
# SENDGRID_API_KEY=

# WhatsApp API
# WHATSAPP_API_TOKEN=

# ============ PRODUCCIÓN - CHECKLIST ============
# [ ] JWT_SECRET cambiado a valor aleatorio seguro
# [ ] JWT_REFRESH_SECRET cambiado a valor aleatorio seguro
# [ ] ADMIN_PASSWORD_HASH configurado con bcryptjs
# [ ] NEXT_PUBLIC_ADMIN_USERNAME cambiado de 'admin'
# [ ] NODE_ENV = production
# [ ] HTTPS habilitado
# [ ] Database credenciales configuradas
# [ ] Logging externo configurado (Sentry, DataDog, etc)

