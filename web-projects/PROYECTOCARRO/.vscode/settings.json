{
  // ===== CONFIGURACIÓN ESPECÍFICA PROYECTOCARRO =====
  // Identidad visual del workspace
  "workbench.colorTheme": "Dracula",
  "peacock.color": "#FF6B9D",
  "peacock.affectActivityBar": true,
  "peacock.affectStatusBar": true,
  // TypeScript/JavaScript
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": true
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": true
    }
  },
  // Next.js específico
  "next.telemetry": false,
  // Excluir carpetas para performance
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/.env.local": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/build": true
  },
  // Prettier
  "prettier.semi": true,
  "prettier.singleQuote": true,
  "prettier.trailingComma": "es5",
  "prettier.printWidth": 100,
  "prettier.tabWidth": 2,
  // ESLint
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.format.enable": true,
  // Tailwind CSS
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    "ngClass"
  ],
  // MongoDB
  "mongodb.connectionSstring": "mongodb://localhost:27017",
  "mongodb.defaultConnectionSstring": "mongodb://localhost:27017",
  // Testing
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}